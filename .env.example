ENV=development

ANTHROPIC_API_KEY=your_anthropic_api_key_here
KIE_API_KEY=your_kie_api_key_here
GROQ_API_KEY=your_groq_api_key_here

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Telegram Login Widget (same bot as converza_bot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=ConverzaSales_bot

# Web proxies /webhook/* to the bot at this internal URL
BOT_INTERNAL_URL=http://localhost:8000

# Production CORS (comma-separated origins allowed in ENV=production)
ALLOWED_ORIGINS=http://localhost:8001

# JWT session after Telegram login (required in production)
JWT_SECRET=dev-insecure-change-me-in-production

# Admin Telegram user ids (comma-separated) — access /admin to approve users
ADMIN_TELEGRAM_IDS=your_telegram_user_id

# OpenClaw — not used in v1
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_BEARER_TOKEN=your_openclaw_bearer_token_here
